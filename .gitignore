# =============================================================================
# smart-attendance-backend (Python / FastAPI / Django / Flask)
# =============================================================================

# Byte-compiled / optimized / DLL files
smart-attendance-backend/__pycache__/
smart-attendance-backend/**/__pycache__/
smart-attendance-backend/*.py[cod]
smart-attendance-backend/**/*.py[cod]
smart-attendance-backend/*$py.class

# Virtual environments
smart-attendance-backend/.venv/
smart-attendance-backend/venv/
smart-attendance-backend/env/
smart-attendance-backend/.env/
smart-attendance-backend/ENV/

# Distribution / packaging
smart-attendance-backend/.eggs/
smart-attendance-backend/*.egg-info/
smart-attendance-backend/dist/
smart-attendance-backend/build/
smart-attendance-backend/*.egg

# pytest / coverage
smart-attendance-backend/.pytest_cache/
smart-attendance-backend/.coverage
smart-attendance-backend/htmlcov/
smart-attendance-backend/coverage.xml
smart-attendance-backend/.tox/

# mypy / type checking
smart-attendance-backend/.mypy_cache/
smart-attendance-backend/.dmypy.json

# Ruff / linting
smart-attendance-backend/.ruff_cache/

# Database files (local / fallback — primary DB is PostgreSQL via Supabase)
smart-attendance-backend/*.db
smart-attendance-backend/*.sqlite
smart-attendance-backend/*.sqlite3

# PostgreSQL local dump files
smart-attendance-backend/*.sql
smart-attendance-backend/*.dump
smart-attendance-backend/*.pgdump
smart-attendance-backend/*.backup
smart-attendance-backend/pg_dump/
smart-attendance-backend/db_backups/

# SQLAlchemy / Alembic
smart-attendance-backend/alembic/versions/*.pyc
# Keep migration scripts — do NOT ignore alembic/versions/*.py
# Ignore autogenerated local config overrides
smart-attendance-backend/alembic.ini.local

# Supabase CLI
smart-attendance-backend/.supabase/
smart-attendance-backend/supabase/.temp/
smart-attendance-backend/supabase/functions/.env
# Keep supabase/config.toml and migrations in version control
!smart-attendance-backend/supabase/config.toml
!smart-attendance-backend/supabase/migrations/

# Root-level Supabase (if CLI is run from repo root)
.supabase/
supabase/.temp/
supabase/functions/.env
!supabase/config.toml
!supabase/migrations/

# Logs
smart-attendance-backend/*.log
smart-attendance-backend/logs/

# Celery
smart-attendance-backend/celerybeat-schedule
smart-attendance-backend/celerybeat.pid

# Media / uploaded files
smart-attendance-backend/media/
smart-attendance-backend/static_collected/


